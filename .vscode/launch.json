{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Hangman",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Hangman/bin/Debug/net9.0/Hangman.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Hangman",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Attach to Process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}